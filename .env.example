# These are set automatically by `npx convex dev`:
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Frontend-only env var — must match AUTH_GOOGLE_ID on the Convex deployment.
# The Google OAuth client ID is public (embedded in the frontend JS).
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Optional — only needed if you enable Discord integration.
VITE_DISCORD_CLIENT_ID=your_discord_application_id

# Docker runtime variables (used by docker-compose.yml / docker run -e).
# These are injected into /config.json at container startup.
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site
GOOGLE_CLIENT_ID=your_google_client_id
# Optional — only needed if you enable Discord integration.
DISCORD_CLIENT_ID=your_discord_application_id

# The following are Convex server-side environment variables.
# They are NOT set in this file — they live on the Convex deployment.
# Use `npx convex env list` to view them.
#
# Required:
#   SITE_URL=http://localhost:5173        (frontend URL for OAuth callback redirect)
#   AUTH_GOOGLE_ID=your_google_client_id  (Google OAuth client ID)
#   AUTH_GOOGLE_SECRET=your_google_client_secret (Google OAuth client secret)
#
# Required for Discord integration (optional feature):
#   DISCORD_APP_ID=...                    (Discord application ID — same as client ID)
#   DISCORD_BOT_TOKEN=...                 (Discord bot token from Bot tab)
#   DISCORD_PUBLIC_KEY=...                (Ed25519 public key from General Information tab)
#   DISCORD_DEBOUNCE_MS=300000            (optional, default 5 minutes — debounce window
#                                          before a locked-slot change is announced)
