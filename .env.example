# These are set automatically by `npx convex dev`:
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# The following are Convex server-side environment variables.
# They are NOT set in this file — they live on the Convex deployment.
# Use `npx convex env list` to view them.
#
# Set automatically by `npx @convex-dev/auth`:
#   SITE_URL=http://localhost:5173        (frontend URL for OAuth redirects)
#   JWT_PRIVATE_KEY=...                   (RSA private key for signing JWTs)
#   JWKS=...                              (public key for verifying JWTs)
#
# Set manually (see README for details):
#   AUTH_GOOGLE_ID=your_google_client_id
#   AUTH_GOOGLE_SECRET=your_google_client_secret
